{
  "$schema_version": "1",
  "suite_id": "apple_client_perf",
  "description": "Apple 客户端（iPhone Simulator）性能基线契约。每个场景定义必需证据键与数值阈值，比较器 check_apple_client_perf_regression.py 据此输出 pass/warn/fail 报告。",
  "device": "iphone",
  "simulator": "iPhone 16 / iOS 18.6",
  "scenarios": [
    {
      "scenario_id": "chat_stream",
      "description": "聊天流式输出（stream_heavy，300 次 delta flush）",
      "surface_id": "chat_session",
      "required_evidence_keys": [
        "hotspot_key=ios_ai_chat",
        "hotspot_key_secondary=mac_ai_chat",
        "tail_flush_event=aiMessageTailFlush",
        "memory_snapshot_key=memory_snapshot"
      ],
      "metrics": [
        {
          "metric_id": "aiMessageTailFlush_p95_ms",
          "description": "流式 tail flush P95 耗时（毫秒），从 aiMessageTailFlush 日志中提取 duration_ms",
          "log_pattern": "perf aiMessageTailFlush",
          "value_key": "duration_ms",
          "warn_limit": 50.0,
          "fail_limit": 200.0,
          "unit": "ms"
        }
      ]
    },
    {
      "scenario_id": "evolution_panel",
      "description": "Evolution 面板性能（evolution_panel，50 轮 timeline recompute）",
      "surface_id": "evolution_workspace",
      "required_evidence_keys": [
        "evolution_recompute_key=evolution_timeline_recompute_ms",
        "evolution_tier_change_key=evolution_monitor tier_change",
        "memory_snapshot_key=memory_snapshot"
      ],
      "metrics": [
        {
          "metric_id": "evolution_timeline_recompute_p95_ms",
          "description": "Evolution 面板 timeline 重算 P95 耗时（毫秒），从 evolution_timeline_recompute_ms 日志中提取值",
          "log_pattern": "perf evolution_timeline_recompute_ms=",
          "value_key": "evolution_timeline_recompute_ms",
          "warn_limit": 50.0,
          "fail_limit": 200.0,
          "unit": "ms"
        }
      ]
    },
    {
      "scenario_id": "chat_stream_workspace_switch",
      "description": "聊天流式输出 + 工作区切换高负载（100 次 delta flush × 3 次工作区切换），必须由真实 fixture 产出独立证据",
      "surface_id": "chat_session",
      "required_evidence_keys": [
        "hotspot_key=ios_ai_chat",
        "tail_flush_event=aiMessageTailFlush",
        "memory_snapshot_key=memory_snapshot",
        "workspace_switch_event=workspace_switch"
      ],
      "required_event_fields": [
        {
          "event_key": "workspace_switch_event=workspace_switch",
          "fields": [
            "project",
            "workspace",
            "scenario",
            "surface",
            "workspace_context"
          ]
        }
      ],
      "metrics": [
        {
          "metric_id": "aiMessageTailFlush_p95_ms",
          "description": "流式 tail flush P95 耗时（毫秒），工作区切换场景",
          "log_pattern": "perf aiMessageTailFlush",
          "value_key": "duration_ms",
          "warn_limit": 60.0,
          "fail_limit": 250.0,
          "unit": "ms"
        },
        {
          "metric_id": "workspace_switch_p95_ms",
          "description": "工作区切换 P95 耗时（毫秒）",
          "log_pattern": "perf workspace_switch",
          "value_key": "duration_ms",
          "warn_limit": 300.0,
          "fail_limit": 1000.0,
          "unit": "ms"
        }
      ]
    },
    {
      "scenario_id": "evolution_panel_multi_workspace",
      "description": "Evolution 面板并行工作区采样（3 个工作区，各 30 轮 recompute），必须由真实 fixture 产出独立证据",
      "surface_id": "evolution_workspace",
      "required_evidence_keys": [
        "evolution_recompute_key=evolution_timeline_recompute_ms",
        "evolution_tier_change_key=evolution_monitor tier_change",
        "memory_snapshot_key=memory_snapshot",
        "multi_workspace_event=evolution_multi_workspace_sample"
      ],
      "required_event_fields": [
        {
          "event_key": "multi_workspace_event=evolution_multi_workspace_sample",
          "fields": [
            "project",
            "workspace",
            "scenario",
            "surface",
            "workspace_context",
            "cycle_id"
          ]
        }
      ],
      "metrics": [
        {
          "metric_id": "evolution_timeline_recompute_p95_ms",
          "description": "Evolution 面板 timeline 重算 P95 耗时，并行工作区场景",
          "log_pattern": "perf evolution_timeline_recompute_ms=",
          "value_key": "evolution_timeline_recompute_ms",
          "warn_limit": 60.0,
          "fail_limit": 250.0,
          "unit": "ms"
        }
      ]
    },
    {
      "scenario_id": "terminal_output",
      "description": "终端输出刷新性能（100 次 flush），由真实终端 fixture 产出独立证据",
      "surface_id": "terminal_output",
      "required_evidence_keys": [
        "terminal_flush_event=terminal_output_flush",
        "memory_snapshot_key=memory_snapshot"
      ],
      "required_event_fields": [
        {
          "event_key": "terminal_flush_event=terminal_output_flush",
          "fields": [
            "project",
            "workspace",
            "scenario",
            "surface",
            "workspace_context",
            "term_id"
          ]
        }
      ],
      "metrics": [
        {
          "metric_id": "terminalOutputFlush_p95_ms",
          "description": "终端输出刷新 P95 耗时（毫秒），从 terminalOutputFlush 日志中提取 duration_ms",
          "log_pattern": "perf terminalOutputFlush",
          "value_key": "duration_ms",
          "warn_limit": 50.0,
          "fail_limit": 200.0,
          "unit": "ms"
        }
      ]
    },
    {
      "scenario_id": "terminal_output_multi_workspace",
      "description": "终端输出刷新多工作区场景（3 个工作区，各 30 轮 flush），必须由真实 fixture 产出独立证据",
      "surface_id": "terminal_output",
      "required_evidence_keys": [
        "terminal_flush_event=terminal_output_flush",
        "memory_snapshot_key=memory_snapshot",
        "multi_workspace_event=terminal_multi_workspace_sample"
      ],
      "required_event_fields": [
        {
          "event_key": "terminal_flush_event=terminal_output_flush",
          "fields": [
            "project",
            "workspace",
            "scenario",
            "surface",
            "workspace_context",
            "term_id"
          ]
        },
        {
          "event_key": "multi_workspace_event=terminal_multi_workspace_sample",
          "fields": [
            "project",
            "workspace",
            "scenario",
            "surface",
            "workspace_context",
            "term_id"
          ]
        }
      ],
      "metrics": [
        {
          "metric_id": "terminalOutputFlush_p95_ms",
          "description": "终端输出刷新 P95 耗时，多工作区场景",
          "log_pattern": "perf terminalOutputFlush",
          "value_key": "duration_ms",
          "warn_limit": 60.0,
          "fail_limit": 250.0,
          "unit": "ms"
        }
      ]
    },
    {
      "scenario_id": "git_panel",
      "description": "Git 面板投影重算性能（50 轮重算），由真实 Git 面板 fixture 产出独立证据",
      "surface_id": "git_panel",
      "required_evidence_keys": [
        "git_panel_projection_event=git_panel_projection",
        "memory_snapshot_key=memory_snapshot"
      ],
      "required_event_fields": [
        {
          "event_key": "git_panel_projection_event=git_panel_projection",
          "fields": [
            "project",
            "workspace",
            "scenario",
            "surface",
            "workspace_context"
          ]
        },
        {
          "event_key": "perf gitPanelProjection",
          "fields": [
            "project",
            "workspace",
            "scenario",
            "workspace_context",
            "staged_count",
            "unstaged_count",
            "untracked_count",
            "item_count"
          ]
        }
      ],
      "metrics": [
        {
          "metric_id": "gitPanelProjection_p95_ms",
          "description": "Git 面板投影重算 P95 耗时（毫秒），从 gitPanelProjection 日志中提取 duration_ms",
          "log_pattern": "perf gitPanelProjection",
          "value_key": "duration_ms",
          "warn_limit": 50.0,
          "fail_limit": 200.0,
          "unit": "ms"
        }
      ]
    },
    {
      "scenario_id": "git_panel_multi_workspace",
      "description": "Git 面板投影重算多工作区场景（3 个工作区，各 30 轮重算），必须由真实 fixture 产出独立证据",
      "surface_id": "git_panel",
      "required_evidence_keys": [
        "git_panel_projection_event=git_panel_projection",
        "memory_snapshot_key=memory_snapshot",
        "multi_workspace_event=git_panel_multi_workspace_sample"
      ],
      "required_event_fields": [
        {
          "event_key": "git_panel_projection_event=git_panel_projection",
          "fields": [
            "project",
            "workspace",
            "scenario",
            "surface",
            "workspace_context"
          ]
        },
        {
          "event_key": "multi_workspace_event=git_panel_multi_workspace_sample",
          "fields": [
            "project",
            "workspace",
            "scenario",
            "surface",
            "workspace_context"
          ]
        },
        {
          "event_key": "perf gitPanelProjection",
          "fields": [
            "project",
            "workspace",
            "scenario",
            "workspace_context",
            "staged_count",
            "unstaged_count",
            "untracked_count",
            "item_count"
          ]
        }
      ],
      "metrics": [
        {
          "metric_id": "gitPanelProjection_p95_ms",
          "description": "Git 面板投影重算 P95 耗时，多工作区场景",
          "log_pattern": "perf gitPanelProjection",
          "value_key": "duration_ms",
          "warn_limit": 60.0,
          "fail_limit": 250.0,
          "unit": "ms"
        }
      ]
    }
  ]
}
