{
  "$schema_version": "1",
  "suite_id": "apple_client_perf",
  "description": "Apple 客户端（iPhone Simulator）性能基线契约。每个场景定义必需证据键与数值阈值，比较器 check_apple_client_perf_regression.py 据此输出 pass/warn/fail 报告。",
  "device": "iphone",
  "simulator": "iPhone 16 / iOS 18.6",
  "scenarios": [
    {
      "scenario_id": "chat_stream",
      "description": "聊天流式输出（stream_heavy，300 次 delta flush）",
      "required_evidence_keys": [
        "hotspot_key=ios_ai_chat",
        "hotspot_key_secondary=mac_ai_chat",
        "tail_flush_event=aiMessageTailFlush",
        "memory_snapshot_key=memory_snapshot"
      ],
      "metrics": [
        {
          "metric_id": "aiMessageTailFlush_p95_ms",
          "description": "流式 tail flush P95 耗时（毫秒），从 aiMessageTailFlush 日志中提取 duration_ms",
          "log_pattern": "perf aiMessageTailFlush",
          "value_key": "duration_ms",
          "warn_limit": 50.0,
          "fail_limit": 200.0,
          "unit": "ms"
        }
      ]
    },
    {
      "scenario_id": "evolution_panel",
      "description": "Evolution 面板性能（evolution_panel，50 轮 timeline recompute）",
      "required_evidence_keys": [
        "evolution_recompute_key=evolution_timeline_recompute_ms",
        "evolution_tier_change_key=evolution_monitor tier_change",
        "memory_snapshot_key=memory_snapshot"
      ],
      "metrics": [
        {
          "metric_id": "evolution_timeline_recompute_p95_ms",
          "description": "Evolution 面板 timeline 重算 P95 耗时（毫秒），从 evolution_timeline_recompute_ms 日志中提取值",
          "log_pattern": "perf evolution_timeline_recompute_ms=",
          "value_key": "evolution_timeline_recompute_ms",
          "warn_limit": 50.0,
          "fail_limit": 200.0,
          "unit": "ms"
        }
      ]
    }
  ]
}
