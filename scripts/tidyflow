#!/usr/bin/env bash
# TidyFlow 统一脚本入口
# 目标：把日常开发、校验与发布入口收敛到单命令，降低脚本分散带来的维护成本。

set -euo pipefail

PROJECT_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$PROJECT_ROOT"

build_quality_gate_args() {
    local has_run_id=0
    local args=("$@")
    local arg
    for arg in "${args[@]}"; do
        if [ "$arg" = "--run-id" ]; then
            has_run_id=1
            break
        fi
    done

    if [ $has_run_id -eq 0 ]; then
        local generated_run_id
        generated_run_id="$(date -u +%Y%m%d-%H%M%S)"
        echo "[tidyflow] quality-gate 自动生成 run_id=$generated_run_id" >&2
        args+=("--run-id" "$generated_run_id")
    fi

    printf "%s\n" "${args[@]}"
}

print_usage() {
    cat <<'EOF'
用法:
  ./scripts/tidyflow <command> [args...]

命令:
  dev
      本地联调（等价于 ./scripts/run-app.sh）

  test
      运行 Core 测试（cargo test --manifest-path core/Cargo.toml）

  check
      运行架构护栏检查：
      - 协议一致性检查
      - 协议 schema 同步检查
      - 协议代码生成同步检查
      - 协议 Swift 规则生成同步检查
      - 协议 action 规则同步检查
      - 版本一致性检查

  quality-gate --cycle <cycle_id> [--run-id <run_id>] [--step all|build|integration|verify] [--dry-run]
      运行 Evolution 质量门禁链路（unit -> integration -> e2e -> manual，build 独立门禁）

  build dmg [--skip-core] [--sign] [--identity "..."]
      构建 DMG（透传到 ./scripts/build_dmg.sh）

  notarize [--profile <profile>] [--dmg <path>]
      公证 DMG（透传到 ./scripts/notarize.sh）

  release [--dry-run|--upload-release ...]
      本地发布链路（透传到 ./scripts/release_local.sh）
      发布前默认要求证据完整（build_log/test_log/screenshot/diff_summary/metrics）
EOF
}

cmd="${1:-}"
if [ -z "$cmd" ]; then
    print_usage
    exit 1
fi
shift || true

case "$cmd" in
    dev)
        exec ./scripts/run-app.sh "$@"
        ;;
    test)
        exec cargo test --manifest-path core/Cargo.toml "$@"
        ;;
    check)
        ./scripts/tools/check_protocol_consistency.sh
        ./scripts/tools/check_protocol_schema_sync.sh
        ./scripts/tools/gen_protocol_action_table.sh --check
        ./scripts/tools/gen_protocol_action_swift_rules.sh --check
        ./scripts/tools/check_protocol_action_sync.sh
        ./scripts/tools/check_version_consistency.sh
        ;;
    quality-gate)
        quality_gate_args=()
        while IFS= read -r line; do
            quality_gate_args+=("$line")
        done < <(build_quality_gate_args "$@")
        exec ./scripts/evo-run.sh "${quality_gate_args[@]}"
        ;;
    build)
        sub="${1:-}"
        if [ "$sub" != "dmg" ]; then
            echo "[tidyflow] 仅支持: build dmg"
            exit 1
        fi
        shift || true
        exec ./scripts/build_dmg.sh "$@"
        ;;
    notarize)
        exec ./scripts/notarize.sh "$@"
        ;;
    release)
        exec ./scripts/release_local.sh "$@"
        ;;
    help|-h|--help)
        print_usage
        ;;
    *)
        echo "[tidyflow] 未知命令: $cmd"
        print_usage
        exit 1
        ;;
esac
