#!/usr/bin/env bash
# TidyFlow 统一脚本入口
# 目标：把日常开发、校验与发布入口收敛到单命令，降低脚本分散带来的维护成本。

set -euo pipefail

PROJECT_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$PROJECT_ROOT"

print_usage() {
    cat <<'EOF'
用法:
  ./scripts/tidyflow <command> [args...]

命令:
  dev
      本地联调（等价于 ./scripts/run-app.sh）

  bench [args...]
      运行 Core 性能基准测试（cargo bench --manifest-path core/Cargo.toml）
      示例：./scripts/tidyflow bench workspace_cache
      热点三类路径基准：./scripts/tidyflow bench hotspot_perf_recording
      文件索引过滤热路径：./scripts/tidyflow bench file_index_filter_hot

  test
      运行 Core 测试（cargo test --manifest-path core/Cargo.toml）

  coverage [args...]
      运行 Core 覆盖率采集（透传到 ./scripts/tools/coverage.sh）

  target-stats [--check]
      查看 Core target 目录占用与缓存回收状态

  check
      运行架构护栏检查：
      - 协议一致性检查
      - 协议 schema 同步检查
      - 协议代码生成同步检查
      - 协议 Swift 规则生成同步检查
      - 协议 action 规则同步检查
      - 版本一致性检查

  lint
      运行 Core 代码质量门禁（fmt + clippy 零告警）：
      - cargo fmt --check（格式一致性）
      - cargo clippy -D warnings --all-targets（全量零告警）

  e2e [--device iphone|ipad|mac|all] [--run-id <run_id>]
      运行端到端测试，并由测试代码自动产出证据与 evidence.index.json

  quality-gate --cycle <cycle_id> [--run-id <run_id>] [--step all|protocol_check|core_regression|performance_regression|system_health|evidence_integrity|apple_regression|apple_build] [--dry-run] [--verify-only] [--project <name>] [--workspace <name>] [--json] [--skip-apple]
      统一质量门禁入口，明确阶段划分和失败语义，所有链路共享

  perf-regression [--json]
      热点性能回归检查（自动执行守卫二进制 + 比较器）：
        1. cargo run --bin hotspot_perf_guard -- --output build/perf/hotspot-measurements.json
        2. python3 scripts/tools/check_hotspot_perf_regression.py
      输出: build/perf/hotspot-regression-report.json
      --json: 打印 JSON 比较报告到 stdout
      overall=fail 返回非 0（阻断门禁）

  apple-build [macos|ios] [--skip-core]
      构建 Apple 客户端（Debug），用于验证改动不破坏编译：
        macos: xcodebuild macOS Debug build（platform=macOS）
        ios:   xcodebuild iOS Simulator Debug build（iPhone 16, OS=18.6）
      默认同时构建两端（串行）。--skip-core 强制 SKIP_CORE_BUILD=1。

  apple-regression [--macos-only] [--ios-only]
      运行 Apple 端多工作区定向回归测试（macOS Debug，xcodebuild test）：
        - TidyFlowTests/TerminalWorkspaceIsolationTests
        - TidyFlowTests/WorkspaceSharedStateSemanticsTests
        - TidyFlowTests/EvolutionReplaySessionIsolationTests
        - TidyFlowTests/PerformanceObservabilitySemanticsTests
        - TidyFlowTests/SystemHealthSemanticsTests
      回归目标：验证工作区切换、终端隔离、AI 会话缓存、演化回放与性能可观测语义不会退化。

  perf-test
      运行 Core 性能可观测 + 智能分析摘要 + 自适应调度回归测试（CHK-002）：
        - cargo test system_snapshot_should_include_perf（system_snapshot 协议字段验证）
        - cargo test perf（Core 性能注册表、诊断阈值、工作区/客户端隔离）
        - cargo test hotspot_perf（热点三类路径护栏）
        - cargo test analysis（分析摘要装配与工作区隔离回归）
        - cargo test scheduling（自适应并发建议应用与回退回归）

  apple-perf-test
      运行 Apple 性能可观测共享语义定向测试（CHK-005）：
        - TidyFlowTests/PerformanceObservabilitySemanticsTests
        - TidyFlowTests/SystemHealthSemanticsTests
      仅运行 macOS 平台，SKIP_CORE_BUILD=1。

  build dmg [--skip-core] [--sign] [--identity "..."]
      构建 DMG（透传到 ./scripts/build_dmg.sh）

  notarize [--profile <profile>] [--dmg <path>]
      公证 DMG（透传到 ./scripts/notarize.sh）

  release [--dry-run|--upload-release ...]
      本地发布链路（透传到 ./scripts/release_local.sh）
      发布前默认要求证据完整（build_log/test_log/screenshot/diff_summary/metrics）
EOF
}

run_core_cargo() {
    local action="$1"
    shift || true

    ./scripts/tools/core_target_guard.sh prepare "$action"
    set +e
    "$@"
    local exit_code=$?
    set -e
    ./scripts/tools/core_target_guard.sh finalize "$action"
    return "$exit_code"
}

resolve_workspace_cache_bench_bin() {
    local target_dir="$1"
    find "$target_dir/release/deps" \
        -maxdepth 1 \
        -type f \
        -name 'workspace_cache_bench-*' \
        ! -name '*.d' \
        ! -name '*.o' \
        -print | sort | tail -n 1
}

run_bench_command() {
    if [[ "${1:-}" == "workspace_cache" ]]; then
        shift
        local target_dir="$PROJECT_ROOT/core/target/bench-target"
        local bench_bin
        run_core_cargo \
            bench \
            env \
            CARGO_TARGET_DIR="$target_dir" \
            CARGO_PROFILE_BENCH_LTO=false \
            CARGO_PROFILE_BENCH_CODEGEN_UNITS=16 \
            cargo build --profile bench --manifest-path core/Cargo.toml --bench workspace_cache_bench
        bench_bin="$(resolve_workspace_cache_bench_bin "$target_dir")"
        if [[ -z "$bench_bin" ]]; then
            echo "[tidyflow] 未找到 workspace_cache bench 可执行文件"
            exit 1
        fi
        "$bench_bin" workspace_cache "$@"
        return
    fi

    run_core_cargo \
        bench \
        env CARGO_TARGET_DIR="$PROJECT_ROOT/core/target/bench-target" \
        cargo bench --manifest-path core/Cargo.toml "$@"
}

# 构建 macOS Debug
build_macos() {
    local skip_core="${1:-1}"
    echo "[tidyflow] 构建 macOS Debug (SKIP_CORE_BUILD=$skip_core)..."
    xcodebuild \
        -project "$PROJECT_ROOT/app/TidyFlow.xcodeproj" \
        -scheme TidyFlow \
        -configuration Debug \
        -destination 'platform=macOS' \
        -derivedDataPath "$PROJECT_ROOT/build" \
        "SKIP_CORE_BUILD=$skip_core" \
        build
}

# 构建 iOS Simulator Debug
build_ios() {
    local skip_core="${1:-1}"
    echo "[tidyflow] 构建 iOS Simulator Debug (SKIP_CORE_BUILD=$skip_core)..."
    xcodebuild \
        -project "$PROJECT_ROOT/app/TidyFlow.xcodeproj" \
        -scheme TidyFlow \
        -configuration Debug \
        -destination 'platform=iOS Simulator,name=iPhone 16,OS=18.6' \
        -derivedDataPath "$PROJECT_ROOT/build" \
        "SKIP_CORE_BUILD=$skip_core" \
        build
}

resolve_perf_fixture_run_id() {
    if [[ -n "${EVIDENCE_RUN_ID:-}" ]]; then
        printf '%s' "$EVIDENCE_RUN_ID"
        return
    fi
    if [[ -n "${CYCLE_RUN_ID:-}" ]]; then
        printf '%s' "$CYCLE_RUN_ID"
        return
    fi
    if [[ -n "${TF_E2E_RUN_ID:-}" ]]; then
        printf '%s' "$TF_E2E_RUN_ID"
        return
    fi
    printf '%s' "$(date -u +%Y%m%d-%H%M%S)"
}

prepare_perf_fixture_evidence_context() {
    local device="${1:?device required}"
    local run_id="${2:?run_id required}"
    local evidence_root="$PROJECT_ROOT/.tidyflow/evidence"
    mkdir -p "$evidence_root/$device/e2e/$run_id"
    cat > "$evidence_root/.run-context.json" <<EOF
{
  "device_type": "$device",
  "run_id": "$run_id",
  "evidence_root": "$evidence_root"
}
EOF
}

run_apple_chat_perf_fixture() {
    local perf_dir="$PROJECT_ROOT/build/perf"
    local derived_data="$PROJECT_ROOT/build/perf-fixture"
    local scenario_slug="chat-stream"
    local evidence_run_id
    evidence_run_id="$(resolve_perf_fixture_run_id)"
    local xcode_log="$perf_dir/apple-${scenario_slug}-fixture-xcodebuild.log"
    local oslog_file="$perf_dir/apple-${scenario_slug}-fixture-oslog.log"
    local hotspot_file="$perf_dir/apple-${scenario_slug}-fixture-hotspots.log"
    local tail_flush_file="$perf_dir/apple-${scenario_slug}-fixture-tail-flush.log"
    local memory_file="$perf_dir/apple-${scenario_slug}-fixture-memory.log"
    local evidence_root="$PROJECT_ROOT/.tidyflow/evidence/iphone/e2e"
    local fixture_evidence_log=""
    local simulator_name="iPhone 16"
    local simulator_os="18.6"
    local simulator_id="AAE135DC-E91E-4B02-9754-270D96B1BD5C"

    mkdir -p "$perf_dir"
    rm -f "$xcode_log" "$oslog_file" "$hotspot_file" "$tail_flush_file" "$memory_file"
    prepare_perf_fixture_evidence_context "iphone" "$evidence_run_id"

    echo "[tidyflow] 运行 Apple 聊天流式 fixture（iOS Simulator）..."
    EVIDENCE_RUN_ID="$evidence_run_id" \
    CYCLE_RUN_ID="$evidence_run_id" \
    TF_E2E_RUN_ID="$evidence_run_id" \
    TF_PERF_SCENARIO=stream_heavy \
    TF_PERF_CHAT_SCENARIO=stream_heavy \
    UI_TEST_MODE=1 \
    xcodebuild \
        -project "$PROJECT_ROOT/app/TidyFlow.xcodeproj" \
        -scheme TidyFlow \
        -configuration Debug \
        -destination "platform=iOS Simulator,name=$simulator_name,OS=$simulator_os" \
        -derivedDataPath "$derived_data" \
        SKIP_CORE_BUILD=1 \
        TF_PERF_SCENARIO=stream_heavy \
        TF_PERF_CHAT_SCENARIO=stream_heavy \
        UI_TEST_MODE=1 \
        test \
        -only-testing:TidyFlowE2ETests/TidyFlowE2ETests/testAC_CHAT_PERF_FIXTURE_IPHONE \
        -skip-testing:TidyFlowTests \
        | tee "$xcode_log"

    fixture_evidence_log="$(
        find "$evidence_root/$evidence_run_id" -path '*/ac-chat-perf-fixture/*.log' -type f -print 2>/dev/null \
            | xargs ls -t 2>/dev/null \
            | head -n 1
    )"
    if [[ -z "$fixture_evidence_log" || ! -f "$fixture_evidence_log" ]]; then
        echo "[tidyflow] 未找到 Apple 聊天 fixture 证据日志"
        return 1
    fi

    echo "[tidyflow] 导出 Apple 聊天 fixture 证据日志..."
    cp "$fixture_evidence_log" "$oslog_file"

    grep -E 'hotspot_key(=.*|_secondary=.*)' "$oslog_file" > "$hotspot_file" || true
    grep 'tail_flush_event=aiMessageTailFlush' "$oslog_file" > "$tail_flush_file" || true
    grep 'memory_snapshot_key=memory_snapshot' "$oslog_file" > "$memory_file" || true
    touch "$oslog_file"

    if [[ ! -s "$hotspot_file" ]]; then
        echo "[tidyflow] 未采集到 swiftui_hotspot 聊天日志"
        return 1
    fi
    if ! grep -q 'hotspot_key=ios_ai_chat' "$hotspot_file"; then
        echo "[tidyflow] 缺少 ios_ai_chat hotspot 日志"
        return 1
    fi
    if ! grep -q 'hotspot_key_secondary=mac_ai_chat' "$hotspot_file"; then
        echo "[tidyflow] 缺少 mac_ai_chat hotspot 日志"
        return 1
    fi
    if [[ ! -s "$tail_flush_file" ]]; then
        echo "[tidyflow] 未采集到 aiMessageTailFlush 样本"
        return 1
    fi
    if [[ ! -s "$memory_file" ]]; then
        echo "[tidyflow] 未采集到 memory_snapshot 样本"
        return 1
    fi

    echo "[tidyflow] Apple 聊天流式 fixture 通过 (run_id=$evidence_run_id)"
    echo "[tidyflow] fixture 证据: $fixture_evidence_log"
    echo "[tidyflow] hotspot 证据: $hotspot_file"
    echo "[tidyflow] tail flush 证据: $tail_flush_file"
    echo "[tidyflow] memory 证据: $memory_file"
}

# run_apple_evolution_perf_fixture: 执行 Evolution 面板性能 fixture，提取日志证据
run_apple_evolution_perf_fixture() {
    local perf_dir="$PROJECT_ROOT/build/perf"
    local derived_data="$PROJECT_ROOT/build/perf-fixture"
    local evidence_run_id
    evidence_run_id="$(resolve_perf_fixture_run_id)"
    local xcode_log="$perf_dir/apple-evolution-panel-fixture-xcodebuild.log"
    local oslog_file="$perf_dir/apple-evolution-panel-fixture-oslog.log"
    local recompute_file="$perf_dir/apple-evolution-panel-fixture-recompute.log"
    local tier_change_file="$perf_dir/apple-evolution-panel-fixture-tier-change.log"
    local memory_file="$perf_dir/apple-evolution-panel-fixture-memory.log"
    local evidence_root="$PROJECT_ROOT/.tidyflow/evidence/iphone/e2e"
    local fixture_evidence_log=""
    local simulator_name="iPhone 16"
    local simulator_os="18.6"

    mkdir -p "$perf_dir"
    rm -f "$xcode_log" "$oslog_file" "$recompute_file" "$tier_change_file" "$memory_file"
    prepare_perf_fixture_evidence_context "iphone" "$evidence_run_id"

    echo "[tidyflow] 运行 Apple Evolution 面板 fixture（iOS Simulator）..."
    EVIDENCE_RUN_ID="$evidence_run_id" \
    CYCLE_RUN_ID="$evidence_run_id" \
    TF_E2E_RUN_ID="$evidence_run_id" \
    TF_PERF_SCENARIO=evolution_panel \
    UI_TEST_MODE=1 \
    xcodebuild \
        -project "$PROJECT_ROOT/app/TidyFlow.xcodeproj" \
        -scheme TidyFlow \
        -configuration Debug \
        -destination "platform=iOS Simulator,name=$simulator_name,OS=$simulator_os" \
        -derivedDataPath "$derived_data" \
        SKIP_CORE_BUILD=1 \
        TF_PERF_SCENARIO=evolution_panel \
        UI_TEST_MODE=1 \
        test \
        -only-testing:TidyFlowE2ETests/TidyFlowE2ETests/testAC_EVOLUTION_PERF_FIXTURE_IPHONE \
        -skip-testing:TidyFlowTests \
        | tee "$xcode_log"

    fixture_evidence_log="$(
        find "$evidence_root/$evidence_run_id" -path '*/ac-evolution-perf-fixture/*.log' -type f -print 2>/dev/null \
            | xargs ls -t 2>/dev/null \
            | head -n 1
    )"
    if [[ -z "$fixture_evidence_log" || ! -f "$fixture_evidence_log" ]]; then
        echo "[tidyflow] 未找到 Apple Evolution fixture 证据日志"
        return 1
    fi

    echo "[tidyflow] 导出 Apple Evolution fixture 证据日志..."
    cp "$fixture_evidence_log" "$oslog_file"

    grep -E 'evolution_timeline_recompute_ms=' "$oslog_file" > "$recompute_file" || true
    grep -E 'evolution_monitor tier_change' "$oslog_file" > "$tier_change_file" || true
    grep 'memory_snapshot_key=memory_snapshot' "$oslog_file" > "$memory_file" || true
    touch "$oslog_file"

    if [[ ! -s "$recompute_file" ]]; then
        echo "[tidyflow] 未采集到 evolution_timeline_recompute_ms 样本"
        return 1
    fi
    if [[ ! -s "$tier_change_file" ]]; then
        echo "[tidyflow] 未采集到 evolution_monitor tier_change 日志"
        return 1
    fi
    if [[ ! -s "$memory_file" ]]; then
        echo "[tidyflow] 未采集到 memory_snapshot 样本"
        return 1
    fi

    echo "[tidyflow] Apple Evolution 面板 fixture 通过 (run_id=$evidence_run_id)"
    echo "[tidyflow] fixture 证据: $fixture_evidence_log"
    echo "[tidyflow] recompute 证据: $recompute_file"
    echo "[tidyflow] tier_change 证据: $tier_change_file"
    echo "[tidyflow] memory 证据: $memory_file"
}

# run_apple_client_perf_regression: 依次执行 chat + evolution fixture，运行 Apple 客户端比较器
run_apple_client_perf_regression() {
    local perf_dir="$PROJECT_ROOT/build/perf"
    local report="$perf_dir/apple-client-regression-report.json"
    mkdir -p "$perf_dir"

    echo "[tidyflow] === Apple 客户端性能基线回归 ==="

    local chat_ok=0
    local evolution_ok=0

    echo "[tidyflow] [1/2] 聊天流式 fixture..."
    if run_apple_chat_perf_fixture; then
        chat_ok=1
        echo "[tidyflow] 聊天 fixture: pass"
    else
        echo "[tidyflow] 聊天 fixture: fail" >&2
    fi

    echo "[tidyflow] [2/2] Evolution 面板 fixture..."
    if run_apple_evolution_perf_fixture; then
        evolution_ok=1
        echo "[tidyflow] Evolution fixture: pass"
    else
        echo "[tidyflow] Evolution fixture: fail" >&2
    fi

    echo "[tidyflow] 运行 Apple 客户端性能比较器..."
    python3 "$PROJECT_ROOT/scripts/tools/check_apple_client_perf_regression.py" \
        --baseline "$PROJECT_ROOT/scripts/tools/apple_client_perf_baselines.json" \
        --evidence-dir "$perf_dir" \
        --report "$report"
    local comparator_exit=$?

    echo "[tidyflow] Apple 客户端性能报告: $report"

    if [[ $chat_ok -eq 0 || $evolution_ok -eq 0 || $comparator_exit -ne 0 ]]; then
        echo "[tidyflow] Apple 客户端性能回归: fail（chat_ok=$chat_ok evolution_ok=$evolution_ok comparator=$comparator_exit）" >&2
        return 1
    fi
    echo "[tidyflow] Apple 客户端性能回归: pass"
    return 0
}

cmd="${1:-}"
if [ -z "$cmd" ]; then
    print_usage
    exit 1
fi
shift || true

case "$cmd" in
    dev)
        exec ./scripts/run-app.sh "$@"
        ;;
    bench)
        run_bench_command "$@"
        ;;
    test)
        ncpu="$(nproc 2>/dev/null || sysctl -n hw.ncpu 2>/dev/null || echo 4)"
        run_core_cargo \
            test \
            cargo test --manifest-path core/Cargo.toml --jobs "$ncpu" "$@"
        ;;
    perf-test)
        # Core 性能可观测 + 智能分析摘要 + 自适应调度回归测试（CHK-002）
        echo "[tidyflow] 运行 Core 性能可观测与分析摘要定向测试..."
        run_core_cargo \
            test \
            cargo test --manifest-path core/Cargo.toml system_snapshot_should_include_perf -- --nocapture
        run_core_cargo \
            test \
            cargo test --manifest-path core/Cargo.toml perf -- --nocapture
        run_core_cargo \
            test \
            cargo test --manifest-path core/Cargo.toml hotspot_perf -- --nocapture
        # WI-001/WI-002 新增：分析摘要装配与调度建议回归测试
        run_core_cargo \
            test \
            cargo test --manifest-path core/Cargo.toml analysis -- --nocapture
        run_core_cargo \
            test \
            cargo test --manifest-path core/Cargo.toml scheduling -- --nocapture
        ;;
    apple-perf-test)
        # Apple 性能可观测共享语义定向测试（CHK-005）
        echo "[tidyflow] 运行 Apple 性能可观测共享语义测试（macOS）..."
        xcodebuild \
            -project "$PROJECT_ROOT/app/TidyFlow.xcodeproj" \
            -scheme TidyFlow \
            -configuration Debug \
            -destination 'platform=macOS' \
            -derivedDataPath "$PROJECT_ROOT/build/perf-tests" \
            SKIP_CORE_BUILD=1 \
            -only-testing:TidyFlowTests/PerformanceObservabilitySemanticsTests \
            -only-testing:TidyFlowTests/SystemHealthSemanticsTests \
            test
        ;;
    coverage)
        exec ./scripts/tools/coverage.sh "$@"
        ;;
    target-stats)
        exec ./scripts/tools/core_target_guard.sh stats "$@"
        ;;
    check)
        ./scripts/tools/check_protocol_consistency.sh
        ./scripts/tools/check_protocol_schema_sync.sh
        ./scripts/tools/gen_protocol_action_table.sh --check
        ./scripts/tools/gen_protocol_action_swift_rules.sh --check
        ./scripts/tools/check_protocol_action_sync.sh
        ./scripts/tools/check_version_consistency.sh
        ;;
    lint)
        run_core_cargo \
            lint \
            cargo fmt --manifest-path core/Cargo.toml --all --check
        run_core_cargo \
            lint \
            cargo clippy --manifest-path core/Cargo.toml --all-targets -- -D warnings
        ;;
    e2e)
        exec ./scripts/e2e/main.sh "$@"
        ;;
    perf-regression)
        # 热点性能回归检查：守卫二进制 + 比较器
        json_flag=0
        for arg in "$@"; do
            [[ "$arg" == "--json" ]] && json_flag=1
        done
        echo "[tidyflow] 运行热点性能守卫..."
        mkdir -p "$PROJECT_ROOT/build/perf"
        cargo run \
            --manifest-path "$PROJECT_ROOT/core/Cargo.toml" \
            --bin hotspot_perf_guard \
            -- --output "$PROJECT_ROOT/build/perf/hotspot-measurements.json"
        echo "[tidyflow] 运行回归比较器..."
        comparator_args=(
            --baseline "$PROJECT_ROOT/core/benches/baselines/hotspot_regression.json"
            --measurements "$PROJECT_ROOT/build/perf/hotspot-measurements.json"
            --report "$PROJECT_ROOT/build/perf/hotspot-regression-report.json"
        )
        # 注意：--json 仅传给契约工具（统一报告输出），不传给单独的比较器
        # Core 热点比较器：捕获 exit code 以确保 apple + 契约工具始终执行
        set +e
        python3 "$PROJECT_ROOT/scripts/tools/check_hotspot_perf_regression.py" "${comparator_args[@]}"
        _hotspot_exit=$?
        set -e
        # Apple 客户端性能基线回归（聊天流式 + Evolution 面板，统一输出 apple-client-regression-report.json）
        set +e
        run_apple_client_perf_regression
        _apple_exit=$?
        set -e
        # 生成统一性能门禁报告（WI-002）
        echo "[tidyflow] 生成统一性能门禁报告..."
        _gate_contract_args=(
            --contract "$PROJECT_ROOT/scripts/tools/performance_gate_contract.json"
            --project "${TF_PROJECT:-tidyflow}"
            --workspace "${TF_WORKSPACE:-default}"
            --cycle-id "${CYCLE_ID:-}"
            --run-id "$(resolve_perf_fixture_run_id)"
            --output "$PROJECT_ROOT/build/perf/performance-gate-report.json"
        )
        if [[ $json_flag -eq 1 ]]; then
            _gate_contract_args+=(--json)
        fi
        set +e
        python3 "$PROJECT_ROOT/scripts/tools/check_perf_gate_contract.py" "${_gate_contract_args[@]}"
        _gate_exit=$?
        set -e
        # 综合返回：任意一步失败则整体失败
        if [[ $_hotspot_exit -ne 0 || $_apple_exit -ne 0 || $_gate_exit -ne 0 ]]; then
            exit 1
        fi
        ;;
    quality-gate)
        exec ./scripts/e2e/quality-gate.sh "$@"
        ;;
    apple-build)
        sub="${1:-both}"
        skip_core=1
        for arg in "$@"; do
            [[ "$arg" == "--skip-core" ]] && skip_core=1
        done
        case "$sub" in
            macos)
                build_macos "$skip_core"
                ;;
            ios)
                build_ios "$skip_core"
                ;;
            both|--skip-core)
                # 串行：先 macOS 再 iOS
                build_macos "$skip_core"
                build_ios "$skip_core"
                ;;
            *)
                echo "[tidyflow] apple-build 支持: macos | ios（默认两端串行）"
                exit 1
                ;;
        esac
        ;;
    apple-regression)
        macos_only=0
        ios_only=0
        for arg in "$@"; do
            [[ "$arg" == "--macos-only" ]] && macos_only=1
            [[ "$arg" == "--ios-only" ]] && ios_only=1
        done
        regression_tests=(
            "-only-testing:TidyFlowTests/TerminalWorkspaceIsolationTests"
            "-only-testing:TidyFlowTests/WorkspaceSharedStateSemanticsTests"
            "-only-testing:TidyFlowTests/EvolutionReplaySessionIsolationTests"
            "-only-testing:TidyFlowTests/PerformanceObservabilitySemanticsTests"
            "-only-testing:TidyFlowTests/SystemHealthSemanticsTests"
        )
        if [[ $ios_only -eq 0 ]]; then
            echo "[tidyflow] 运行 macOS 多工作区定向回归..."
            xcodebuild \
                -project "$PROJECT_ROOT/app/TidyFlow.xcodeproj" \
                -scheme TidyFlow \
                -configuration Debug \
                -destination 'platform=macOS' \
                -derivedDataPath "$PROJECT_ROOT/build" \
                SKIP_CORE_BUILD=1 \
                test \
                "${regression_tests[@]}"
        fi
        if [[ $macos_only -eq 0 ]]; then
            echo "[tidyflow] 运行 iOS Simulator 多工作区定向回归..."
            xcodebuild \
                -project "$PROJECT_ROOT/app/TidyFlow.xcodeproj" \
                -scheme TidyFlow \
                -configuration Debug \
                -destination 'platform=iOS Simulator,name=iPhone 16,OS=18.6' \
                -derivedDataPath "$PROJECT_ROOT/build" \
                SKIP_CORE_BUILD=1 \
                test \
                "${regression_tests[@]}"
        fi
        ;;
    build)
        sub="${1:-}"
        if [ "$sub" != "dmg" ]; then
            echo "[tidyflow] 仅支持: build dmg"
            exit 1
        fi
        shift || true
        exec ./scripts/build_dmg.sh "$@"
        ;;
    notarize)
        exec ./scripts/notarize.sh "$@"
        ;;
    release)
        exec ./scripts/release_local.sh "$@"
        ;;
    help|-h|--help)
        print_usage
        ;;
    *)
        echo "[tidyflow] 未知命令: $cmd"
        print_usage
        exit 1
        ;;
esac
